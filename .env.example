# IBM Quantum
IBM_QUANTUM_TOKEN=your_ibm_quantum_api_token

# Solana
SOLANA_KEYPAIR_PATH=./wallet-keypair.json
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Token defaults
DEV_BUY_SOL=0.0001
CIRCUIT_STYLE=soft
SHOTS=8192

# Token links
TOKEN_WEBSITE=https://github.com/yourorg/yourrepo

# Token description (pump.fun) — IBM job ID is appended dynamically at runtime
TOKEN_DESCRIPTION=This token's name and artwork were generated by a 20-qubit quantum circuit executed on a real IBM Quantum Processing Unit — not a chatbot wrapper, not a simulator, not an AI agent with a quantum API bolted on. The measurement results from 8,192 shots on physical superconducting qubits determined the name, and the token deployment transaction was triggered directly by the quantum job pipeline. Verify: query the IBM Job ID below at quantum.cloud.ibm.com, pull the measurement results, take the most-measured 20-bit string, split into four 5-bit groups, map 0-25 to A-Z — you'll get this token's name.
